# Copy to .env and fill in as each milestone needs it. Nothing beyond
# DATABASE_URL is required to run M0-M4 (scaffolding through the walking
# skeleton) against local Docker Postgres+PostGIS.

# -----------------------------------------------------------------------------
# Local development — required now
# -----------------------------------------------------------------------------
# Local Postgres + PostGIS via `docker compose up -d` (see docker-compose.yml).
# Must match docker-compose.yml's POSTGRES_USER/PASSWORD/DB if you change either.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/go_adventure_dev?schema=public"

# -----------------------------------------------------------------------------
# Admin (M6, interim) — /admin password gate until Google OAuth + is_admin (M7).
# Defaults to "admin" in non-production; MUST be set in production.
# -----------------------------------------------------------------------------
# ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Auth — Roadmap M7. Session strategy undecided: docs/adr/0002-authjs-session-strategy.md
# AUTH_SECRET also signs the interim admin session cookie (M6).
# -----------------------------------------------------------------------------
# AUTH_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# -----------------------------------------------------------------------------
# Ingestion sources — Roadmap M5 (NPS first) / M9 (remaining sources).
# Do not request/use any of these until the source has a reviewed registry
# entry: docs/adr/0006-source-licences-and-refresh-contracts.md (undecided)
# and the PRD's Source Registry table.
# -----------------------------------------------------------------------------
# NPS_API_KEY=
# RECREATION_GOV_API_KEY=
# OPEN_METEO_API_KEY=          # only if/when the paid commercial tier is required
# USGS and OpenStreetMap/Overpass are keyless at documented volume — confirm at M9

# -----------------------------------------------------------------------------
# AI-assisted editorial drafting — Roadmap M8. Provider/terms undecided:
# docs/adr/0007-ai-provider-and-data-handling.md
# -----------------------------------------------------------------------------
# GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Media storage (Cloudflare R2) — needed starting M5/M6 (source captures,
# media approval queue).
# -----------------------------------------------------------------------------
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Map tiles — provider undecided: docs/adr/0005-map-tile-provider.md
# -----------------------------------------------------------------------------
# MAP_TILES_API_KEY=

# -----------------------------------------------------------------------------
# Public site URL — used by robots.txt and sitemap.xml (M11). Defaults to
# http://localhost:3000 in dev; set to the production origin when deployed.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL=https://travel-roamer.com

# -----------------------------------------------------------------------------
# Observability & analytics — Roadmap M10. The event dictionary + consent gate
# exist in code; these wire the sinks at deploy time.
# -----------------------------------------------------------------------------
# SENTRY_DSN=
# NEXT_PUBLIC_GTM_ID=
# NEXT_PUBLIC_GA4_ID=

# -----------------------------------------------------------------------------
# Production only (Supabase-hosted) — not needed for local Docker dev.
# Supabase's pooled (pgbouncer) connection typically needs a separate,
# unpooled DIRECT_URL for Prisma migrations. Confirm exact variable names
# against Supabase's connection docs when provisioning the real project.
# -----------------------------------------------------------------------------
# DIRECT_URL=
